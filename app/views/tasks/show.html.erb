<div class="card shadow-sm">
  <div class="card-body">
    <div class="d-flex align-items-center gap-2 mb-2">
      <% if @task.completed %>
        <i class="fa-solid fa-circle-check text-success"></i>
        <h1 class="card-title h3 text-decoration-line-through text-muted mb-0"><%= @task.title %></h1>
      <% else %>
        <i class="fa-regular fa-circle text-secondary"></i>
        <h1 class="card-title h3 mb-0"><%= @task.title %></h1>
      <% end %>
    </div>

    <span class="badge <%= @task.completed ? 'bg-success' : 'bg-secondary' %> mb-3">
      <%= @task.completed ? "Completed" : "In progress" %>
    </span>

    <% if @task.details.present? %>
      <p class="card-text"><%= @task.details %></p>
    <% end %>
  </div>

  <div class="card-footer d-flex gap-2">
    <%= link_to tasks_path, class: "btn btn-outline-secondary btn-sm" do %>
      <i class="fa-solid fa-arrow-left me-1"></i>Back
    <% end %>
    <%= link_to edit_task_path(@task), class: "btn btn-outline-primary btn-sm" do %>
      <i class="fa-solid fa-pen me-1"></i>Edit
    <% end %>
    <%= link_to task_path(@task), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-outline-danger btn-sm ms-auto" do %>
      <i class="fa-solid fa-trash me-1"></i>Delete
    <% end %>
  </div>
</div>
