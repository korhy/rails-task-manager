<%= form_with model: task do |form| %>
  <div class="mb-3">
    <%= form.label :title, class: "form-label fw-semibold" %>
    <%= form.text_field :title, class: "form-control", placeholder: "Task title" %>
  </div>

  <div class="mb-3">
    <%= form.label :details, class: "form-label fw-semibold" %>
    <%= form.text_area :details, class: "form-control", rows: 4, placeholder: "Optional details..." %>
  </div>

  <% unless task.new_record? %>
    <div class="mb-3 form-check">
      <%= form.check_box :completed, class: "form-check-input" %>
      <%= form.label :completed, class: "form-check-label" %>
    </div>
  <% end %>

  <%= form.submit (task.new_record? ? "Create Task" : "Update Task"), :class => "btn btn-primary" %>
<% end %>
